{
  "info": {
    "_postman_id": "d4f50826-4f71-4d2d-9a9f-a2d8940b9f2b",
    "name": "agent_service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for agents/s02/agent_service.py"
  },
  "item": [
    {
      "name": "POST /chat",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"session_id\": \"{{session_id}}\",\n  \"message\": \"你好，帮我看下当前项目结构\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/chat",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "chat"
          ]
        },
        "description": "Send user message to an existing session."
      },
      "response": []
    },
    {
      "name": "POST /new",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code === 200) {",
              "  const data = pm.response.json();",
              "  if (data && data.session_id) {",
              "    pm.collectionVariables.set('session_id', data.session_id);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"session_id\": \"{{session_id}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/new",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "new"
          ]
        },
        "description": "Reset current session context and return a new session_id."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:5015"
    },
    {
      "key": "user_id",
      "value": "u1001"
    },
    {
      "key": "session_id",
      "value": "s-init-001"
    }
  ]
}
